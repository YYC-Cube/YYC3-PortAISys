# YYC³ PortAISys — pnpm 配置
# 国内镜像源 + 加大超时/重试，解决 @prisma/dev 等庞大依赖树的 install 超时
# CI（GitHub Actions ubuntu runner）有 ~/.pnpm-store 缓存兜底，切镜像影响可控

registry=https://registry.npmmirror.com

# 单次请求超时从默认 60s 提到 120s
fetch-timeout=120000

# 重试次数从默认 2 提到 5
fetch-retries=5

# 重试指数退避因子（默认 2），大包更耐网络抖动
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
