{
  "cSpell.words": ["YYC3", "Retryable", "retryable", "yyc3"],
  "editor.codeActions.triggerOnFocusChange": true,
  "githubPullRequests.queries": [
    {
      "label": "Pull Requests",
      "query": "is:open repo:${owner}/${repository}"
    }
  ],
  "githubPullRequests.showPullRequestNumber": true,
  "githubPullRequests.defaultMergeMethod": "merge",
  "markdown.extension.completion.enabled": false,
  "markdown.extension.tableFormatter.enabled": false,
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": ".github/workflows/*"
  }
}
